<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Lead Form</title>

  <style>
    body{
      font-family: Arial;
      background: linear-gradient(135deg,#4f46e5,#06b6d4);
      display:flex;
      justify-content:center;
      align-items:center;
      height:100vh;
    }

    .card{
      background:white;
      padding:25px;
      border-radius:15px;
      width:100%;
      max-width:420px;
      box-shadow:0 10px 30px rgba(0,0,0,0.2);
    }

    input, textarea{
      width:100%;
      margin:10px 0;
      padding:12px;
      border:1px solid #ddd;
      border-radius:10px;
    }

    button{
      width:100%;
      padding:12px;
      background:#4f46e5;
      color:white;
      border:none;
      border-radius:10px;
      cursor:pointer;
    }

    button:hover{
      background:#4338ca;
    }

    #result{
      margin-top:10px;
      text-align:center;
    }
  </style>
</head>

<body>

<div class="card">
  <h2>Form Order</h2>

  <form id="leadForm">
    <input type="text" id="name" placeholder="Nama" required>
    <input type="text" id="whatsapp" placeholder="WhatsApp" required>
    <input type="email" id="email" placeholder="Email (opsional)">
    <textarea id="kebutuhan" placeholder="Ceritakan kebutuhan Anda" rows="5"></textarea>

    <button type="submit">Kirim</button>
  </form>

  <div id="result"></div>
</div>

<script src="script.js"></script>

</body>
</html>
